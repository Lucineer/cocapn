{
  "name": "create-cocapn",
  "version": "0.1.0",
  "description": "Two-repo scaffolder for Cocapn agent instances",
  "type": "module",
  "bin": {
    "create-cocapn": "./bin/create-cocapn.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import ../local-bridge/node_modules/tsx/dist/esm/index.cjs --test tests/scaffold.test.ts",
    "prepublishOnly": "echo ready"
  },
  "keywords": [
    "ai",
    "agent",
    "runtime",
    "self-hosted",
    "llm",
    "mcp",
    "fleet",
    "cocapn",
    "superinstance",
    "scaffold",
    "create"
  ],
  "author": "Superinstance <team@superinstance.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CedarBeach2019/cocapn"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ]
}
